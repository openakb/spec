{
  "$schema": "https://schema.openakb.org/v1/openakb.schema.json",
  "id": "invalid-wrong-reference-kind",
  "title": "Invalid — wrong reference kind",
  "description": "A section source_ids entry names a section instead of a source.",
  "sources": [
    {
      "id": "s1",
      "type": "url",
      "uri": "https://docs.example.com/a/"
    }
  ],
  "sections": [
    {
      "id": "root",
      "title": "Root",
      "description": "This section cites another section as if it were a source.",
