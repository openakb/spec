{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openakb.org/v1/openakb.schema.json",
  "title": "OpenAKB descriptor",
  "description": "JSON Schema for an OpenAKB descriptor (openakb.json). Lenient on unknown members by design (no additionalProperties:false on core objects) so minor versions stay forward-compatible; typo-catching is the validator's strict mode (spec §6).",
  "type": "object",
  "required": ["$schema", "id", "title", "description", "sources", "sections"],
  "properties": {
    "$schema": { "type": "string", "format": "uri", "pattern": "^https://schema\\.openakb\\.org/v1(\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*))?/openakb\\.schema\\.json$" },
    "id": { "$ref": "#/$defs/localId" },
    "namespace": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 64 },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "subject_type": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 40 } },
    "language": { "$ref": "#/$defs/language" },
    "guide_uri": { "type": "string", "format": "uri-reference" },
    "guide_hash": { "$ref": "#/$defs/sriHash" },
    "guide_length": { "type": "integer", "minimum": 0 },
    "revision": { "type": "string" },
    "base_uri": { "type": "string", "format": "uri-reference" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" },
    "sources": { "type": "array", "minItems": 1, "maxItems": 100000, "items": { "$ref": "#/$defs/source" } },
    "sections": { "type": "array", "minItems": 1, "maxItems": 10000, "items": { "$ref": "#/$defs/section" } },
    "x": { "$ref": "#/$defs/extensions" }
  },
  "$defs": {
    "localId": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 64 },
    "language": { "type": "string", "pattern": "^[A-Za-z0-9]+(-[A-Za-z0-9]+)*$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|\\+00:00)$", "description": "RFC 3339 UTC profile: uppercase T separator, uppercase Z or +00:00 offset. The pattern pins the grammar; full calendar validation (month/day ranges) additionally requires a format-asserting validator." },
    "sriHash": { "type": "string", "pattern": "^[a-z0-9]+-(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{4}|[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)$" },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$" },
      "additionalProperties": { "type": "object" }
    },
    "source": {
      "type": "object",
      "required": ["id", "type", "uri"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "type": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "format": "uri-reference", "minLength": 1 },
        "title": { "type": "string", "maxLength": 200 },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "content_hash": { "$ref": "#/$defs/sriHash" },
        "capture_uri": { "type": "string", "format": "uri-reference", "minLength": 1 },
        "content_length": { "type": "integer", "minimum": 0 },
        "refresh_class": { "type": "string", "minLength": 1 },
        "cadence": { "type": "string", "minLength": 1 },
        "discovered_via_id": { "$ref": "#/$defs/localId" },
        "x": { "$ref": "#/$defs/extensions" }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "description"],
      "if": { "required": ["content_uri"], "properties": { "content_uri": true } },
      "then": { "required": ["source_ids"], "properties": { "source_ids": { "type": "array", "minItems": 1 } } },
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "parent_id": { "$ref": "#/$defs/localId" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "purpose": { "type": "string", "maxLength": 2000 },
        "content_uri": { "type": "string", "format": "uri-reference" },
        "content_type": { "type": "string", "minLength": 1 },
        "content_hash": { "$ref": "#/$defs/sriHash" },
        "content_length": { "type": "integer", "minimum": 0 },
        "language": { "$ref": "#/$defs/language" },
        "source_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/localId" } },
        "provenance": { "type": "array", "minItems": 1, "maxItems": 256, "items": { "$ref": "#/$defs/claim" } },
        "provenance_uri": { "type": "string", "format": "uri-reference" },
        "provenance_hash": { "$ref": "#/$defs/sriHash" },
        "provenance_length": { "type": "integer", "minimum": 0 },
        "links": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/link" } },
        "refreshed_at": { "$ref": "#/$defs/timestamp" },
        "x": { "$ref": "#/$defs/extensions" }
      }
    },
    "claim": {
      "type": "object",
      "required": ["text", "source_ids"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/localId" } },
        "locator": {
          "type": "object",
          "properties": {
            "quote": { "type": "string", "minLength": 1 },
            "page": { "type": "integer", "minimum": 0 },
            "anchor": { "type": "string" },
            "x": { "$ref": "#/$defs/extensions" }
          }
        },
        "x": { "$ref": "#/$defs/extensions" }
      }
    },
    "link": {
      "type": "object",
      "required": ["rel"],
      "anyOf": [
        { "required": ["section_id"], "properties": { "section_id": true } },
        { "required": ["akb_uri"], "properties": { "akb_uri": true } }
      ],
      "properties": {
        "rel": {
          "type": "string",
          "anyOf": [
            { "enum": ["see-also", "related", "depends-on", "prerequisite", "extends", "part-of"] },
            { "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+:[a-z0-9-]+$" }
          ]
        },
        "section_id": { "$ref": "#/$defs/localId" },
        "akb_uri": { "type": "string", "format": "uri-reference" },
        "revision": { "type": "string" },
        "content_hash": { "$ref": "#/$defs/sriHash" },
        "description": { "type": "string", "maxLength": 500 },
        "x": { "$ref": "#/$defs/extensions" }
      }
    }
  }
}
