{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openakb.org/v1/provenance.schema.json",
  "title": "OpenAKB provenance sidecar",
  "description": "Per-section claim-level provenance sidecar (spec §4.4). One sidecar per section. Cross-file consistency (section_id and source_ids resolving into the descriptor) is checked by the validator, not this schema.",
  "type": "object",
  "required": ["section_id", "claims"],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "section_id": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 64 },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "source_ids"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 64 } },
          "locator": {
            "type": "object",
            "properties": {
              "quote": { "type": "string" },
              "page": { "type": "integer", "minimum": 0 },
              "anchor": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
