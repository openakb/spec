{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openakb.org/v1/openakb.schema.json",
  "title": "OpenAKB descriptor",
  "description": "JSON Schema for an OpenAKB descriptor (openakb.json). Lenient on unknown members by design (no additionalProperties:false on core objects) so minor versions stay forward-compatible; typo-catching is the validator's --strict lint (spec §8).",
  "type": "object",
  "required": ["$schema", "id", "title", "description", "sources", "sections"],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "id": { "$ref": "#/$defs/localId" },
    "namespace": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 64 },
    "title": { "type": "string", "minLength": 1, "maxLength": 100 },
    "description": { "type": "string", "minLength": 1, "maxLength": 600 },
    "subject_type": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "maxItems": 32, "items": { "type": "string", "pattern": "^[a-z0-9-]+$", "maxLength": 40 } },
    "language": { "$ref": "#/$defs/language" },
    "guide_uri": { "type": "string", "format": "uri-reference" },
    "revision": { "type": "string" },
    "base_uri": { "type": "string", "format": "uri-reference" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" },
    "sources": { "type": "array", "minItems": 1, "maxItems": 10000, "items": { "$ref": "#/$defs/source" } },
    "sections": { "type": "array", "minItems": 1, "maxItems": 10000, "items": { "$ref": "#/$defs/section" } },
    "x": { "$ref": "#/$defs/extensions" }
  },
  "$defs": {
    "localId": { "type": "string", "pattern": "^[a-z0-9_-]+$", "maxLength": 64 },
    "language": { "type": "string", "pattern": "^[A-Za-z0-9]+(-[A-Za-z0-9]+)*$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "(Z|\\+00:00)$" },
    "sriHash": { "type": "string", "pattern": "^[a-z0-9]+-[A-Za-z0-9+/]+={0,2}$" },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$" },
      "additionalProperties": { "type": "object" }
    },
    "source": {
      "type": "object",
      "required": ["id", "type", "uri"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "type": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "format": "uri-reference" },
        "title": { "type": "string", "maxLength": 200 },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "refresh_class": { "type": "string", "minLength": 1 },
        "cadence": { "type": "string", "minLength": 1 },
        "x": { "$ref": "#/$defs/extensions" }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "parent_id": { "$ref": "#/$defs/localId" },
        "title": { "type": "string", "minLength": 1, "maxLength": 100 },
        "description": { "type": "string", "minLength": 1, "maxLength": 400 },
        "purpose": { "type": "string", "maxLength": 400 },
        "content_uri": { "type": "string", "format": "uri-reference" },
        "content_type": { "type": "string", "minLength": 1 },
        "content_hash": { "$ref": "#/$defs/sriHash" },
        "content_length": { "type": "integer", "minimum": 0 },
        "language": { "$ref": "#/$defs/language" },
        "source_ids": { "type": "array", "items": { "$ref": "#/$defs/localId" } },
        "provenance": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "provenance_uri": { "type": "string", "format": "uri-reference" },
        "provenance_hash": { "$ref": "#/$defs/sriHash" },
        "links": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/link" } },
        "refreshed_at": { "$ref": "#/$defs/timestamp" },
        "x": { "$ref": "#/$defs/extensions" }
      }
    },
    "claim": {
      "type": "object",
      "required": ["text", "source_ids"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/localId" } },
        "locator": {
          "type": "object",
          "properties": {
            "quote": { "type": "string" },
            "page": { "type": "integer", "minimum": 0 },
            "anchor": { "type": "string" }
          }
        }
      }
    },
    "link": {
      "type": "object",
      "required": ["rel"],
      "properties": {
        "rel": {
          "type": "string",
          "anyOf": [
            { "enum": ["see-also", "related", "depends-on", "prerequisite", "extends", "part-of"] },
            { "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)*:[a-z0-9-]+$" }
          ]
        },
        "section_id": { "$ref": "#/$defs/localId" },
        "akb_uri": { "type": "string", "format": "uri-reference" },
        "revision": { "type": "string" },
        "content_hash": { "$ref": "#/$defs/sriHash" },
        "description": { "type": "string", "maxLength": 200 },
        "x": { "$ref": "#/$defs/extensions" }
      }
    }
  }
}
